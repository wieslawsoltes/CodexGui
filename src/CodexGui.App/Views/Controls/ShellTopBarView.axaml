<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexGui.App.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CodexGui.App.Views.Controls.ShellTopBarView"
             x:DataType="vm:MainWindowViewModel">
    <Border x:Name="Root">
        <Border Classes="topBarCard topBarOverviewCard">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Spacing="2"
                            Margin="0,0,16,8"
                            MinWidth="280"
                            MaxWidth="560">
                    <TextBlock Text="Current workspace"
                               Classes="sectionLabel" />
                    <TextBlock Text="{Binding CurrentWorkspaceTitle}"
                               Classes="topBarHeadline"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CurrentWorkspaceSubtitle}"
                               Classes="bodyText"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding StatusChips}"
                              MaxWidth="760"
                              Margin="0,2,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:StatusChipViewModel">
                            <Border Classes="statusChip"
                                    Background="{Binding SurfaceBrush}"
                                    BorderBrush="{Binding AccentBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Label}" Classes="chipLabel" />
                                    <TextBlock Text="{Binding Value}" Classes="chipValue" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </WrapPanel>
        </Border>
    </Border>
</UserControl>
