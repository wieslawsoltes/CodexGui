<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexGui.App.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CodexGui.App.Views.Controls.ShellNavRailView"
             x:DataType="vm:MainWindowViewModel">
    <Border x:Name="Root">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="10">
            <Border Classes="brandBadge"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0">
                <TextBlock Text="C"
                           Classes="brandGlyph" />
            </Border>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        Spacing="6"
                        Margin="0,8,0,0">
                <Button Classes="railButton"
                        ToolTip.Tip="Thread actions">
                    <Button.Flyout>
                        <Flyout Placement="RightEdgeAlignedTop">
                            <Border Classes="railFlyoutCard"
                                    Width="332">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <TextBlock Text="Thread actions"
                                                   Classes="panelTitle" />
                                        <Border Grid.Column="1"
                                                Classes="topBarInlineBadge"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ThreadCountLabel}"
                                                       Classes="topBarInlineBadgeText" />
                                        </Border>
                                    </Grid>

                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="primaryButton topBarActionButton"
                                                Command="{Binding NewThreadCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="ChatAdd" />
                                                <TextBlock Text="New thread" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding StartReviewCommand}">
                                            <TextBlock Text="Review" />
                                        </Button>
                                        <ToggleButton Classes="panelToggle topBarActionToggle"
                                                      Content="Auto-scroll"
                                                      IsChecked="{Binding AutoScrollMessages, Mode=TwoWay}" />
                                    </WrapPanel>

                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding ForkThreadCommand}">
                                            <TextBlock Text="Fork" />
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding ArchiveThreadCommand}">
                                            <TextBlock Text="Archive" />
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding UnarchiveThreadCommand}">
                                            <TextBlock Text="Unarchive" />
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding RenameThreadCommand}">
                                            <TextBlock Text="Rename" />
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding CompactThreadCommand}">
                                            <TextBlock Text="Compact" />
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding RollbackThreadCommand}">
                                            <TextBlock Text="Rollback" />
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <ic:SymbolIcon Classes="buttonIcon"
                                   Symbol="ChatAdd" />
                </Button>
                <Button Classes="railButton"
                        ToolTip.Tip="Workspace controls">
                    <Button.Flyout>
                        <Flyout Placement="RightEdgeAlignedTop">
                            <Border Classes="railFlyoutCard"
                                    Width="300">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Workspace"
                                               Classes="panelTitle" />

                                    <WrapPanel Orientation="Horizontal">
                                        <ToggleButton Classes="panelToggle topBarActionToggle"
                                                      Content="Rail"
                                                      IsChecked="{Binding ShowNavigationRail, Mode=TwoWay}" />
                                        <ToggleButton Classes="panelToggle topBarActionToggle"
                                                      Content="Sidebar"
                                                      IsChecked="{Binding ShowWorkspacePanel, Mode=TwoWay}" />
                                    </WrapPanel>

                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding ShowThreadsCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="PanelLeft" />
                                                <TextBlock Text="Threads" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding ShowAppsCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="AppsSettings" />
                                                <TextBlock Text="Apps" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding ShowSettingsCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="SettingsChat" />
                                                <TextBlock Text="Settings" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <ic:SymbolIcon Classes="buttonIcon"
                                   Symbol="PanelLeft" />
                </Button>
                <Button Classes="railButton"
                        ToolTip.Tip="Apps"
                        Command="{Binding ShowAppsCommand}">
                    <ic:SymbolIcon Classes="buttonIcon"
                                   Symbol="AppsSettings" />
                </Button>
                <Button Classes="railButton"
                        ToolTip.Tip="Settings"
                        Command="{Binding ShowSettingsCommand}">
                    <ic:SymbolIcon Classes="buttonIcon"
                                   Symbol="SettingsChat" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="0,0,0,12">
                <Button Classes="railButton"
                        ToolTip.Tip="Session and connection">
                    <Button.Flyout>
                        <Flyout Placement="RightEdgeAlignedTop">
                            <Border Classes="railFlyoutCard"
                                     Width="360">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <TextBlock Text="Session"
                                                   Classes="panelTitle" />
                                        <Border Grid.Column="1"
                                                Classes="topBarInlineBadge"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ConnectionState}"
                                                       Classes="topBarInlineBadgeText" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding ConnectionDetail}"
                                               Classes="mutedText"
                                               TextWrapping="Wrap" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Executable or endpoint"
                                                   Classes="sectionLabel" />
                                        <TextBox Classes="commandField"
                                                 Text="{Binding CommandPath}" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Arguments (local process)"
                                                   Classes="sectionLabel" />
                                        <TextBox Classes="commandField"
                                                 Text="{Binding CommandArguments}" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Working directory"
                                                   Classes="sectionLabel" />
                                        <TextBox Classes="commandField"
                                                 Text="{Binding WorkingDirectory}" />
                                    </StackPanel>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="primaryButton topBarActionButton"
                                                Command="{Binding ConnectCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="PlugConnectedCheckmark" />
                                                <TextBlock Text="Connect" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding DisconnectCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="PlugDisconnected" />
                                                <TextBlock Text="Disconnect" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding RefreshCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="ArrowSync" />
                                                <TextBlock Text="Refresh" />
                                            </StackPanel>
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding ReloadMcpServersCommand}">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <ic:SymbolIcon Classes="buttonIcon"
                                                               Symbol="ArrowSync" />
                                                <TextBlock Text="Reload MCP" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding LoginCommand}">
                                            <TextBlock Text="Login" />
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding CancelLoginCommand}"
                                                IsVisible="{Binding HasActiveLogin}">
                                            <TextBlock Text="Cancel login" />
                                        </Button>
                                        <Button Classes="toolbarButton topBarActionButton"
                                                Command="{Binding LogoutCommand}">
                                            <TextBlock Text="Logout" />
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <ic:SymbolIcon Classes="buttonIcon"
                                   Symbol="PlugConnectedCheckmark"
                                   Foreground="{Binding ConnectionBrush}" />
                </Button>
                <Button Classes="railButton"
                        ToolTip.Tip="Refresh"
                        Command="{Binding RefreshCommand}">
                    <ic:SymbolIcon Classes="buttonIcon"
                                   Symbol="ArrowSync" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
