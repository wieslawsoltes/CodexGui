extend "lunet-io/templates"

template_theme_default_mode = "system"

site_project_baseurl = "https://wieslawsoltes.github.io"
site_project_basepath = environment == "dev" ? "" : "/CodexGui"
site_project_name = "CodexGui"
site_project_description = "Native Avalonia desktop client for the Codex app-server protocol."
site_project_logo_path = "/img/codexgui-logo.svg"
site_project_social_banner_path = "/img/codexgui-social-banner.svg"
site_project_banner_background_path = "/img/codexgui-social-banner.svg"
site_project_package_id = "CodexGui"
site_project_github_user = "wieslawsoltes"
site_project_github_repo = "CodexGui"
site_project_owner_name = "Wieslaw Soltes"
site_project_owner_alias = "wieslawsoltes"
site_project_owner_url = "https://github.com/wieslawsoltes"
site_project_twitter_user = "wieslawsoltes"
site_project_content_license_name = "MIT"
site_project_content_license_url = "https://github.com/wieslawsoltes/CodexGui/blob/main/LICENSE"
template_footer_content_license_html = $"- Content licensed under the <a href='{site_project_content_license_url}'>MIT license</a>"

site_project_init

# macOS 15 + lunet 1.0.10 has a Dart Sass platform detection bug.
# Use a CSS-only bundle until upstream SCSS handling is fixed.
with bundle "lite"
    bootstrap = resource "npm:bootstrap" "5.3.8"
    bootstrap_icons = resource "npm:bootstrap-icons" "1.13.1"
    tocbot = resource "npm:tocbot" "4.36.4"
    anchorjs = resource "npm:anchor-js" "5.0.0"
    prismjs = resource "npm:prismjs" "1.30.0"

    css tocbot "/dist/tocbot.css"
    css "/css/prism.css"
    css "/css/template-main.css"
    css "/css/site-overrides.css"

    js "/modules/menus/lunet-menu-async.js"
    js bootstrap "/dist/js/bootstrap.bundle.min.js"
    js anchorjs "/anchor.min.js"
    js tocbot "/dist/tocbot.min.js"
    js prismjs "/prism.js"
    js prismjs "/plugins/autoloader/prism-autoloader.min.js"
    js prismjs "/plugins/toolbar/prism-toolbar.min.js"
    js prismjs "/plugins/copy-to-clipboard/prism-copy-to-clipboard.min.js"
    js prismjs "/plugins/show-language/prism-show-language.min.js"
    js "/js/prism-scriban.js"
    js "/js/main.js"

    for path in template_prism_components
        content prismjs "components/" + path "/js/components/"
    end

    content bootstrap_icons "/font/fonts/bootstrap-icons.*" "/fonts/"

    concat = true
    minify = false
end

with attributes
    match "/**/*.md" {
        bundle: "lite"
    }
end
